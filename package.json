{
  "name": "@lizardbyte/contribkit",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LizardByte/contribkit.git"
  },
  "version": "0.0.0",
  "description": "Toolkit for generating contributor images",
  "license": "MIT",
  "funding": "https://app.lizardbyte.dev",
  "homepage": "https://github.com/LizardByte/contribkit#readme",
  "bugs": {
    "url": "https://github.com/LizardByte/contribkit/issues"
  },
  "keywords": [
    "contributors",
    "sponsors",
    "github-sponsors"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "contribkit": "bin/contribkit.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "stub": "unbuild --stub",
    "dev": "tsx src/cli.ts",
    "test": "npm-run-all test:unit test:report test:lint test:typecheck",
    "test:unit": "jest --coverage",
    "test:report": "jest --reporters=jest-junit",
    "test:lint": "eslint .",
    "test:typecheck": "tsc --noEmit",
    "prepublishOnly": "nr build",
    "release": "bumpp && pnpm publish"
  },
  "dependencies": {
    "@crowdin/crowdin-api-client": "^1.41.2",
    "ansis": "^4.3.0",
    "cac": "^7.0.0",
    "consola": "^3.4.2",
    "dotenv": "^17.4.2",
    "ofetch": "^1.5.1",
    "sharp": "^0.34.5",
    "unconfig": "^7.5.0"
  },
  "devDependencies": {
    "@antfu/ni": "^30.1.0",
    "@antfu/utils": "^9.3.0",
    "@babel/core": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "@codecov/webpack-plugin": "2.0.1",
    "@eslint/js": "^10.0.1",
    "@fast-csv/parse": "^5.0.7",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/node": "^25.9.1",
    "@typescript/native": "npm:typescript@^7.0.0",
    "bumpp": "^11.1.0",
    "d3-hierarchy": "^3.1.2",
    "eslint": "^10.4.0",
    "eslint-plugin-jest": "29.15.4",
    "globals": "17.7.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-junit": "17.0.0",
    "jiti": "^2.7.0",
    "normalize-url": "^9.0.0",
    "npm-run-all2": "9.0.2",
    "p-limit": "^7.3.0",
    "tsx": "^4.22.3",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "unbuild": "^3.6.1"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}"
    ],
    "testEnvironment": "jsdom"
  },
  "resolutions": {
    "contribkit": "workspace:*"
  }
}
